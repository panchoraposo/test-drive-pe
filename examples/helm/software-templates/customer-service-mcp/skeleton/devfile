schemaVersion: 2.2.2
metadata:
  name: ${{values.name}}
  version: 1.0.0
  displayName: "${{values.name}} - Neuralbank MCP"
  description: ${{values.description}}
  language: Java
  projectType: Quarkus
components:
  - name: tools
    container:
      image: registry.redhat.io/devspaces/udi-rhel9:latest
      memoryLimit: 2Gi
      cpuLimit: "1"
      mountSources: true
      volumeMounts:
        - name: m2
          path: /home/user/.m2
  - name: m2
    volume:
      size: 2Gi
commands:
  - id: 00-configure-maven-nexus
    exec:
      component: tools
      commandLine: |
        set -eu
        mkdir -p /home/user/.m2
        SETTINGS="/home/user/.m2/settings.xml"
        if [ -f "${SETTINGS}" ] && grep -q "nexus-repository-manager.maven-repo.svc.cluster.local" "${SETTINGS}"; then
          echo "Maven settings already configured for Nexus."
          exit 0
        fi
        cat > "${SETTINGS}" <<'EOF'
        <settings>
          <mirrors>
            <mirror>
              <id>central</id>
              <mirrorOf>central</mirrorOf>
              <url>http://nexus-repository-manager.maven-repo.svc.cluster.local:8081/repository/maven-central/</url>
            </mirror>
            <mirror>
              <id>redhat-ga</id>
              <mirrorOf>redhat-ga</mirrorOf>
              <url>http://nexus-repository-manager.maven-repo.svc.cluster.local:8081/repository/redhat-ga/</url>
            </mirror>
          </mirrors>
        </settings>
        EOF
        echo "Wrote ${SETTINGS}"
      workingDir: ${PROJECT_SOURCE}
      group:
        kind: build
        isDefault: false
  - id: 01-init-maven
    exec:
      component: tools
      commandLine: |
        if ! mvn --version 2>/dev/null | grep -qE '3\.(8\.[6-9]|8\.[1-9][0-9]|9\.|[1-9][0-9])'; then
          echo "Upgrading Maven..." &&
          curl -sSL https://archive.apache.org/dist/maven/maven-3/3.9.9/binaries/apache-maven-3.9.9-bin.tar.gz | tar xz -C /home/user &&
          echo 'export PATH=/home/user/apache-maven-3.9.9/bin:$PATH' >> /home/user/.bashrc &&
          export PATH=/home/user/apache-maven-3.9.9/bin:$PATH &&
          mvn --version;
        else
          echo "Maven version OK: $(mvn --version | head -1)";
        fi
      workingDir: ${PROJECT_SOURCE}
      group:
        kind: build
        isDefault: false
  - id: 02-build
    exec:
      component: tools
      commandLine: export PATH=/home/user/apache-maven-3.9.9/bin:$PATH && mvn package -DskipTests
      workingDir: ${PROJECT_SOURCE}
      group:
        kind: build
        isDefault: true
  - id: 03-run
    exec:
      component: tools
      commandLine: export PATH=/home/user/apache-maven-3.9.9/bin:$PATH && mvn quarkus:dev
      workingDir: ${PROJECT_SOURCE}
      group:
        kind: run
        isDefault: true
  - id: 04-mcp-inspector
    exec:
      component: tools
      commandLine: "npx @anthropic-ai/mcp-inspector http://localhost:8080/mcp/sse"
      workingDir: ${PROJECT_SOURCE}
      group:
        kind: debug
        isDefault: false
  - id: 05-open-rhda-report
    exec:
      component: tools
      commandLine: |
        REPORT_PATH="${REPORT_PATH:-/tmp/redhatDependencyAnalyticsReport.html}"
        echo "RHDA report path: ${REPORT_PATH}"
        if [ -f "${REPORT_PATH}" ]; then
          ls -lh "${REPORT_PATH}"
          echo "Tip: open it from the file explorer inside Dev Spaces."
        else
          echo "Report file not found yet."
          echo "Generate it in the IDE by opening pom.xml and clicking the pie-chart icon, or right-click pom.xml -> 'Red Hat Dependency Analytics Report...'"
        fi
      workingDir: ${PROJECT_SOURCE}
      group:
        kind: test
        isDefault: false
